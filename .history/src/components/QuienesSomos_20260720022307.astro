---
// ─── Culpa de Godoy ───
import { ArrowRight, Sparkles, ShieldCheck, Flame, HeartHandshake } from "lucide-react";

const pilares = [
  { letter: "E", word: "Experiencia", desc: "Años de trayectoria al servicio de la familia universitaria", Icon: Sparkles },
  { letter: "R", word: "Responsabilidad", desc: "Gestión transparente y compromiso con cada decisión", Icon: ShieldCheck },
  { letter: "E", word: "Esfuerzo", desc: "Trabajo constante para alcanzar metas que benefician a todos", Icon: Flame },
  { letter: "S", word: "Servicio", desc: "Estudiante, docente y administrativo siempre en primer lugar", Icon: HeartHandshake },
];
---

<section id="quienes-somos" class="relative overflow-hidden bg-gradient-to-b from-white via-white to-slate-50 text-slate-900 dark:from-slate-950 dark:via-slate-950 dark:to-slate-900 dark:text-slate-100">
  <!-- Video pequeño centrado borroso -->
  <div class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none sm:items-center sm:justify-center">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="-mt-[18vh] h-[35vh] w-[70vw] max-w-2xl rounded-2xl sm:mt-0 sm:h-[50vh] sm:w-[50vw] sm:rounded-3xl opacity-35 sm:opacity-45 dark:opacity-20"
    >
      <source src="/yupiVid.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="absolute inset-0 z-[1] bg-white/15 dark:bg-slate-950/35"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 py-20 sm:px-8 sm:py-32 lg:px-12">

    <!-- ─── Header centrado ─── -->
    <div class="mx-auto max-w-2xl rounded-[2rem] border border-white/35 bg-white/30 px-5 py-6 text-center shadow-[0_10px_40px_-24px_rgba(15,23,42,0.28)] backdrop-blur-md animate-fade-in-up dark:border-white/10 dark:bg-slate-950/40 dark:shadow-[0_12px_50px_-28px_rgba(0,0,0,0.75)] sm:px-8 sm:py-8">
      <h2 class="font-heading text-3xl font-bold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl dark:text-slate-50">
        Somos el cambio que la{" "}
        <span class="animate-gradient-text">UNC</span>
        {" "}necesita
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base font-bold leading-relaxed text-slate-700 sm:mt-6 sm:text-lg dark:text-slate-200">
        Unimos a docentes, estudiantes, administrativos y egresados con una visión clara:
        una universidad más <span class="font-medium text-slate-950 dark:text-slate-50">innovadora</span>,
        <span class="font-medium text-slate-950 dark:text-slate-50"> inclusiva</span> y
        <span class="font-medium text-slate-950 dark:text-slate-50"> competitiva</span>.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3 sm:mt-10 sm:gap-4">
        <a
          href="#propuesta"
          class="group inline-flex items-center gap-2.5 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-primary/30 sm:px-8 sm:py-3.5"
        >
          Conoce nuestra propuesta
          <ArrowRight className="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
        </a>
        <a
          href="#equipo"
          class="inline-flex items-center gap-2 rounded-full border border-slate-300/60 bg-white/45 px-6 py-3 text-sm font-semibold text-slate-900 backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-slate-400/70 hover:bg-white/65 dark:border-white/15 dark:bg-slate-950/45 dark:text-slate-100 dark:hover:border-white/25 dark:hover:bg-slate-950/60 sm:px-8 sm:py-3.5"
        >
          Conoce al equipo
        </a>
      </div>
    </div>

    <!-- ─── Pilares ERES ─── -->
    <div class="mt-20 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4 lg:gap-4">
      {pilares.map((p, i) => (
        <div
          class="group relative overflow-hidden rounded-2xl border border-white/45 bg-white/45 p-4 backdrop-blur-xl transition-all duration-500 hover:-translate-y-1 hover:bg-white/65 hover:shadow-[0_8px_40px_-12px] hover:shadow-primary/15 dark:border-white/10 dark:bg-slate-950/45 dark:hover:bg-slate-950/60 sm:rounded-3xl sm:p-6 animate-fade-in-up"
          style={`animation-delay: ${300 + i * 80}ms`}
        >
          <p.Icon className="absolute -right-3 -bottom-3 h-24 w-24 sm:h-28 sm:w-28 text-primary/[0.08] transition-all duration-700 group-hover:scale-110 group-hover:text-primary/[0.16] dark:text-white/[0.05] dark:group-hover:text-white/[0.08]" />
          <div class="relative">
            <p class="mb-1.5 text-4xl font-black tracking-tighter text-slate-950 transition-colors duration-500 group-hover:text-primary/20 dark:text-slate-50 sm:text-5xl dark:group-hover:text-primary/25">
              {p.letter}
            </p>
            <h3 class="text-sm font-semibold text-slate-950 dark:text-slate-100 sm:text-base">{p.word}</h3>
            <p class="mt-1 text-[11px] leading-relaxed text-slate-600 dark:text-slate-300 sm:text-[13px]">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
