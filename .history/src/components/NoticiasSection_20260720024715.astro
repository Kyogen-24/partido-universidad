---
import NoticiasCarousel from "./NoticiasCarousel";
---

<section id="noticias" class="relative border-t border-border/40 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-black/55"></div>

  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-white/60">Redes sociales</p>
        <h2 class="font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Últimas noticias
        </h2>
      </div>
      <div class="hidden items-center gap-2 sm:flex">
        <a
          href="https://www.facebook.com/eres.unc.cajamarca"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-4 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
        >
          Facebook
        </a>
        <a
          href="https://www.instagram.com/eres.unc.cajamarca/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-4 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
        >
          Instagram
        </a>
        <a
          href="https://www.tiktok.com/@eres.unc.cajamarca"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-4 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
        >
          TikTok
        </a>
      </div>
    </div>

    <NoticiasCarousel client:visible />

    <div class="mt-8 flex items-center justify-center gap-3 sm:hidden">
      <a
        href="https://www.facebook.com/eres.unc.cajamarca"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-9 items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-4 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
      >
        Facebook
      </a>
      <a
        href="https://www.instagram.com/eres.unc.cajamarca/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-9 items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-4 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
      >
        Instagram
      </a>
      <a
        href="https://www.tiktok.com/@eres.unc.cajamarca"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-9 items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-4 text-xs font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20"
      >
        TikTok
      </a>
    </div>
  </div>
</section>
