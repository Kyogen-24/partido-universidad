---
import "../styles/global.css";
import { Menu, X } from "lucide-react";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Eres UNC — Partido Universitario</title>
    <meta name="description" content="Construyamos juntos la universidad que queremos. Elecciones UNC 2026-2031." />
  </head>
  <body class="relative min-h-screen bg-background text-foreground antialiased">
    <img
      class="pointer-events-none fixed inset-0 -z-10 h-full w-full object-cover opacity-50"
      src="/bg-pattern.png"
      alt=""
      aria-hidden="true"
    />
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-border/40 bg-background/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-2.5 font-heading text-lg font-semibold tracking-tight">
          <img src="/images/LOGO_UNC.png" alt="UNC" class="h-10 w-auto" />
          <span class="h-6 w-px bg-border" />
          <img src="/logo.png" alt="Eres UNC" class="h-10 w-10" />
        </a>
        <nav class="hidden items-center gap-6 md:flex">
          <a href="#equipo" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Equipo</a>
          <a href="#propuesta" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Propuesta</a>
          <a href="#calendario" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Calendario</a>
          <a href="#testimonios" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Testimonios</a>
          <a href="#contacto" class="text-sm text-muted-foreground transition-colors hover:text-foreground">Contacto</a>
          <a href="#contacto" class="inline-flex h-8 items-center rounded-lg bg-primary px-3 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/80">
            Sumate
          </a>
        </nav>
        <button id="menu-toggle" class="flex items-center justify-center md:hidden" aria-label="Menú">
          <Menu class="h-6 w-6" />
        </button>
      </div>
    </header>

    <main class="min-h-screen pt-16">
      <slot />
    </main>

    <footer class="border-t border-border/40 bg-muted/30">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
          <div class="flex items-center gap-2.5 text-sm text-muted-foreground">
            <img src="/images/LOGO_UNC.png" alt="UNC" class="h-8 w-auto" />
            <span class="h-5 w-px bg-border" />
            <img src="/logo.png" alt="Eres UNC" class="h-8 w-auto" />
          </div>
          <nav class="flex gap-6 text-sm text-muted-foreground">
            <a href="#propuesta" class="transition-colors hover:text-foreground">Propuesta</a>
            <a href="#equipo" class="transition-colors hover:text-foreground">Equipo</a>
            <a href="#calendario" class="transition-colors hover:text-foreground">Calendario</a>
            <a href="#contacto" class="transition-colors hover:text-foreground">Contacto</a>
          </nav>
          <p class="text-xs text-muted-foreground">
            &copy; {new Date().getFullYear()} Eres UNC. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
