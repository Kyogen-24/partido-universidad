---
import "../styles/global.css";
import { MoreVertical, X } from "lucide-react";
import NavJoinButton from "@/components/NavJoinButton";

const pageTitle = "Eres UNC — Elecciones UNC 2026-2031 | Cajamarca";
const pageDescription =
  "Movimiento académico ERES UNC para las elecciones 2026 de la Universidad Nacional de Cajamarca. Conoce nuestra propuesta, equipo y plan de gobierno 2026-2031.";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL("/images/LOGO_UNC.png", Astro.site);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Eres UNC",
  alternateName: "Movimiento Académico ERES UNC",
  url: Astro.site?.toString(),
  logo: ogImageUrl.toString(),
  sameAs: [
    "https://www.facebook.com/eres.unc.cajamarca",
    "https://www.instagram.com/eres.unc.cajamarca/",
    "https://www.tiktok.com/@eres.unc.cajamarca",
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NMWCVPKL');</script>
    <!-- End Google Tag Manager -->

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Eres UNC" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class="relative min-h-screen bg-background text-foreground antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NMWCVPKL"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <img
      class="pointer-events-none fixed inset-0 -z-10 h-full w-full object-cover opacity-50"
      src="/bg-pattern.png"
      alt=""
      aria-hidden="true"
    />
    <!-- Navbar: transparent by default, reacts to scroll and background brightness -->
    <header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
      <div class="mx-auto flex h-[4.5rem] w-full items-center justify-between pl-2 pr-4 sm:pl-4 sm:pr-6 lg:pl-6 lg:pr-12">
        <a href="/" class="flex items-center font-heading text-lg font-semibold tracking-tight">
          <img src="/logo.svg" alt="Eres UNC" class="h-11 sm:h-13 w-auto transition-transform duration-300 hover:scale-105" />
        </a>
        <nav id="nav-links" class="hidden items-center gap-6 md:flex">
          <a href="#equipo" class="nav-link text-sm font-medium transition-colors duration-300">Equipo</a>
          <a href="#propuesta" class="nav-link text-sm font-medium transition-colors duration-300">Propuesta</a>
          <a href="#calendario" class="nav-link text-sm font-medium transition-colors duration-300">Calendario</a>
          <a href="#testimonios" class="nav-link text-sm font-medium transition-colors duration-300">Testimonios</a>
          <a href="#contacto" class="nav-link text-sm font-medium transition-colors duration-300">Contacto</a>
        </nav>
        <div class="flex items-center gap-3 ml-auto md:ml-0">
          <NavJoinButton client:load />
          <button id="menu-toggle" class="flex items-center justify-center md:hidden p-1.5" aria-label="Menú">
            <span id="menu-icon-open" class="inline-flex"><MoreVertical className="h-6 w-6" /></span>
            <span id="menu-icon-close" class="hidden"><X className="h-6 w-6" /></span>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="hidden border-t border-border/10 border-b border-border/15 bg-background/80 backdrop-blur-lg shadow-lg md:hidden">
        <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-4 py-4 sm:px-6 lg:px-8">
          <a href="#equipo" class="rounded-lg px-3 py-2.5 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">Equipo</a>
          <a href="#propuesta" class="rounded-lg px-3 py-2.5 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">Propuesta</a>
          <a href="#calendario" class="rounded-lg px-3 py-2.5 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">Calendario</a>
          <a href="#testimonios" class="rounded-lg px-3 py-2.5 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">Testimonios</a>
          <a href="#contacto" class="rounded-lg px-3 py-2.5 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">Contacto</a>
          <NavJoinButton variant="mobile" client:load />
        </nav>
      </div>
    </header>

    <main class="min-h-screen">
      <slot />
    </main>

    <footer class="border-t border-white/10 bg-neutral-900">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
          <div class="flex items-center gap-2.5 text-sm text-white/60">
            <img src="/images/LOGO_UNC.png" alt="UNC" class="h-8 w-auto" />
            <span class="h-5 w-px bg-white/15" />
            <img src="/logo.svg" alt="Eres UNC" class="h-8 w-auto" />
          </div>
          <nav class="flex flex-col items-center gap-3 text-sm text-white/60 sm:flex-row sm:gap-6">
            <a href="#propuesta" class="transition-colors hover:text-white">Propuesta</a>
            <a href="#equipo" class="transition-colors hover:text-white">Equipo</a>
            <a href="#calendario" class="transition-colors hover:text-white">Calendario</a>
            <a href="#contacto" class="transition-colors hover:text-white">Contacto</a>
          </nav>
          <p class="text-xs text-white/45">
            &copy; {new Date().getFullYear()} Eres UNC. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // ── Mobile menu toggle ─────────────────────────────────────
      const toggle = document.getElementById("menu-toggle")!;
      const menu = document.getElementById("mobile-menu")!;
      const iconOpen = document.getElementById("menu-icon-open")!;
      const iconClose = document.getElementById("menu-icon-close")!;

      toggle.addEventListener("click", () => {
        menu.classList.toggle("hidden");
        iconOpen.classList.toggle("hidden");
        iconClose.classList.toggle("hidden");
      });

      menu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menu.classList.add("hidden");
          iconOpen.classList.remove("hidden");
          iconClose.classList.add("hidden");
        });
      });

      // ── Transparent & reactive navbar ─────────────────────────
      const navbar = document.getElementById("navbar")!;
      const navLinks = document.querySelectorAll<HTMLElement>(".nav-link");
      const menuToggleBtn = document.getElementById("menu-toggle")!;

      let isDark = false;
      let isScrolled = false;

      function applyNavStyle() {
        if (isScrolled) {
          // scrolled: frosted glass, use theme foreground
          navbar.style.background = "";
          navbar.style.backdropFilter = "";
          navbar.classList.add(
            "bg-background/90",
            "backdrop-blur-md"
          );
          navLinks.forEach((l) => {
            l.style.color = "";
            l.classList.add("text-foreground");
            l.classList.remove("text-white", "drop-shadow-sm");
          });
          menuToggleBtn.style.color = "";
          document.body.classList.add("nav-scrolled");
          document.body.classList.remove("nav-transparent-dark", "nav-transparent-light");
        } else {
          // at top: fully transparent, adapt text to background
          navbar.classList.remove(
            "border-b",
            "border-white/10",
            "bg-background/90",
            "backdrop-blur-md"
          );
          document.body.classList.remove("nav-scrolled");
          if (isDark) {
            navLinks.forEach((l) => {
              l.classList.remove("text-foreground");
              l.classList.add("text-white", "drop-shadow-sm");
            });
            menuToggleBtn.style.color = "white";
            document.body.classList.add("nav-transparent-dark");
            document.body.classList.remove("nav-transparent-light");
          } else {
            navLinks.forEach((l) => {
              l.classList.remove("text-white", "drop-shadow-sm");
              l.classList.add("text-foreground");
            });
            menuToggleBtn.style.color = "";
            document.body.classList.add("nav-transparent-light");
            document.body.classList.remove("nav-transparent-dark");
          }
        }
      }

      // Detect brightness of the pixel strip directly behind the navbar
      function sampleBackgroundBrightness() {
        // We look at the element at the center of the page, just below the navbar
        const sampleY = navbar.offsetHeight + 2;
        const sampleX = Math.round(window.innerWidth / 2);
        const el = document.elementFromPoint(sampleX, sampleY) as HTMLElement | null;
        if (!el) return;

        // Walk up to find a meaningful background-color
        let bg = "";
        let node: HTMLElement | null = el;
        while (node && node !== document.body.parentElement) {
          const style = window.getComputedStyle(node);
          const c = style.backgroundColor;
          if (c && c !== "rgba(0, 0, 0, 0)" && c !== "transparent") {
            bg = c;
            break;
          }
          node = node.parentElement;
        }

        if (!bg) {
          // fallback: use body background
          bg = window.getComputedStyle(document.body).backgroundColor;
        }

        // Parse rgb/rgba and compute relative luminance
        const match = bg.match(/\d+\.?\d*/g);
        if (!match || match.length < 3) return;
        const [r, g, b] = match.map(Number);
        // sRGB luminance
        const lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        isDark = lum < 0.5;
        applyNavStyle();
      }

      // Scroll listener
      window.addEventListener("scroll", () => {
        isScrolled = window.scrollY > 10;
        applyNavStyle();
        if (!isScrolled) sampleBackgroundBrightness();
      }, { passive: true });

      // Initial sample
      sampleBackgroundBrightness();

      // Re-sample on resize
      window.addEventListener("resize", sampleBackgroundBrightness, { passive: true });
    </script>
  </body>
</html>
