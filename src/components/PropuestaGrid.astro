---
import { FlipCard } from "@/components/animate-ui/components/community/flip-card";

const propuestas = [
  {
    title: "Gestión Institucional",
    summary: "Transparencia, planeamiento estratégico y rendición de cuentas.",
    desc: "Promovemos una administración abierta, ética y eficiente con rendición de cuentas pública, optimización de recursos y participación activa de la comunidad académica.",
    img: "/propuestas/gobernanza.webp",
  },
  {
    title: "Calidad Académica",
    summary: "Programas acreditados, formación actualizada y desarrollo docente.",
    desc: "Impulsamos la acreditación de todas las carreras profesionales, la actualización constante de mallas curriculares y el fortalecimiento continuo del desempeño docente.",
    img: "/propuestas/calidad.webp",
  },
  {
    title: "Investigación e Innovación",
    summary: "Más investigación, internacionalización e innovación aplicada.",
    desc: "Fomentamos la publicación científica, financiamiento de proyectos de investigación, patentes y convenios internacionales para docentes y estudiantes.",
    img: "/propuestas/investigacion.webp",
  },
  {
    title: "Transformación Digital",
    summary: "Trámites digitales, plataformas integradas y servicios en línea.",
    desc: "Digitalización al 100% de trámites académicos y administrativos, plataformas virtuales integradas y servicios en línea eficientes para toda la comunidad.",
    img: "/fondo3.webp",
  },
  {
    title: "Bienestar Universitario",
    summary: "Salud mental, tutorías, inclusión y comedor universitario.",
    desc: "Servicios integrales de salud física y mental, tutorías académicas personalizadas, programas de inclusión equitativa y mejoras sustanciales en el comedor universitario.",
    img: "/fondo.webp",
  },
  {
    title: "Infraestructura",
    summary: "Laboratorios modernos, conectividad y espacios funcionales.",
    desc: "Modernización de laboratorios, equipamiento tecnológico de vanguardia, conectividad de alta velocidad y mantenimiento continuo de los espacios universitarios.",
    img: "/fondo1.webp",
  },
];
---

<section id="propuesta" class="relative overflow-hidden bg-background py-16 sm:py-24 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header (Centered) -->
    <div class="mx-auto max-w-3xl text-center mb-12 sm:mb-16">
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-foreground leading-tight">
        Propuestas para <span class="text-emerald-600 dark:text-emerald-400">transformar <br class="hidden sm:inline" /> la UNC</span>
      </h2>
      <p class="mt-4 text-slate-500 dark:text-slate-400 text-sm sm:text-base leading-relaxed max-w-2xl mx-auto">
        Nuestro compromiso se traduce en acciones concretas para fortalecer la universidad y mejorar la experiencia de toda la comunidad universitaria.
      </p>
    </div>

    <!-- Proposals Grid (3 columns) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {propuestas.map((p) => (
        <FlipCard data={p} client:visible />
      ))}
    </div>

    <!-- Bottom Button -->
    <div class="mt-12 sm:mt-16 flex justify-center">
      <a
        href="/plan-trabajo.pdf"
        target="_blank"
        download
        class="inline-flex items-center gap-2 rounded-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-7 py-3.5 text-sm sm:text-base shadow-md shadow-emerald-600/20 transition-all hover:shadow-lg hover:shadow-emerald-600/30 hover:-translate-y-0.5"
      >
        <span>Ver Plan de Gestión Completo</span>
        <span>→</span>
      </a>
    </div>

  </div>
</section>

