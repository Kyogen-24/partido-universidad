---
import { Play } from "lucide-react";
---

<section class="border-t border-border/40 bg-muted/20">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
      <div class="flex flex-col justify-center">
        <h1 class="font-heading text-4xl font-bold tracking-tight sm:text-5xl">
          LANDING PAGE TEMPLATE
        </h1>
        <h2 class="mt-6 font-heading text-xl font-semibold text-muted-foreground">
          LOREIPSUM TITLE
        </h2>
        <p class="mt-4 text-muted-foreground">
          Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh
          euismod tincidunt ut laoreet dolore magna aliquam erat volutpat.
        </p>
        <div class="mt-8">
          <a
            href="#contacto"
            class="inline-flex h-10 items-center gap-2 rounded-lg bg-primary px-6 text-sm font-medium text-primary-foreground shadow-md shadow-primary/20 transition-all hover:bg-primary/80 hover:shadow-primary/30"
          >
            NEXT
          </a>
        </div>
      </div>
      <div class="relative flex items-center justify-center rounded-2xl bg-muted/50 p-8">
        <div class="flex h-48 w-48 items-center justify-center rounded-full bg-primary/20">
          <Play class="h-16 w-16 text-primary" />
        </div>
      </div>
    </div>
  </div>
</section>
