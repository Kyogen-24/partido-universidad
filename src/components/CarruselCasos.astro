---
import { ChevronLeft, ChevronRight } from "lucide-react";
---

<section class="border-t border-border/40 bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <h2 class="text-center font-heading text-3xl font-bold tracking-tight sm:text-4xl">
      OUR CASES
    </h2>
    <div class="relative mt-12">
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl bg-muted/50 p-6">
          <div class="mb-4 text-xs font-bold uppercase tracking-wider text-foreground">
            LOREIPSUM
          </div>
          <div class="mb-2 text-xs font-semibold uppercase text-foreground">
            DOLOR
          </div>
          <div class="mb-4 text-xs font-semibold uppercase text-foreground">
            TAURUS BIGOR
          </div>
          <p class="text-xs text-muted-foreground">
            sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat.
          </p>
        </div>
        <div class="rounded-2xl bg-muted/50 p-6">
          <div class="flex h-32 items-center justify-center rounded-xl bg-muted/80">
            <div class="h-16 w-16 rounded-full bg-primary/20" />
          </div>
        </div>
        <div class="rounded-2xl bg-muted/50 p-6">
          <div class="flex h-32 items-center justify-center rounded-xl bg-muted/80">
            <div class="h-16 w-16 rounded-full bg-primary/20" />
          </div>
        </div>
      </div>
      <button class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 rounded-full border border-border bg-background p-2 shadow-md transition-all hover:bg-muted">
        <ChevronLeft class="h-5 w-5" />
      </button>
      <button class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 rounded-full border border-border bg-background p-2 shadow-md transition-all hover:bg-muted">
        <ChevronRight class="h-5 w-5" />
      </button>
    </div>
    <div class="mt-6 flex justify-center gap-2">
      <div class="h-2 w-2 rounded-full bg-primary" />
      <div class="h-2 w-2 rounded-full bg-muted-foreground/30" />
      <div class="h-2 w-2 rounded-full bg-muted-foreground/30" />
      <div class="h-2 w-2 rounded-full bg-muted-foreground/30" />
    </div>
  </div>
</section>
