---
import { ArrowRight, Sparkles, ShieldCheck, Flame, HeartHandshake } from "lucide-react";

const pilares = [
  { letter: "E", word: "Experiencia", desc: "Años de trayectoria al servicio de la familia universitaria", Icon: Sparkles },
  { letter: "R", word: "Responsabilidad", desc: "Gestión transparente y compromiso con cada decisión", Icon: ShieldCheck },
  { letter: "E", word: "Esfuerzo", desc: "Trabajo constante para alcanzar metas que benefician a todos", Icon: Flame },
  { letter: "S", word: "Servicio", desc: "Estudiante, docente y administrativo siempre en primer lugar", Icon: HeartHandshake },
];
---

<section id="nuestros-principios" class="relative overflow-hidden bg-white">
  <!-- Video detrás del header -->
  <div class="absolute top-0 left-0 right-0 z-0 pointer-events-none flex justify-center pt-8 sm:pt-16 overflow-visible">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="h-[20vh] sm:h-[30vh] w-auto aspect-square max-w-none rounded-2xl sm:rounded-3xl opacity-30 sm:opacity-40 object-contain"
    >
      <source src="/yupiVid.webm" type="video/webm" />
      <source src="/yupiVid.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 py-20 sm:px-8 sm:py-32 lg:px-12">

    <!-- ─── Header centrado ─── -->
    <div class="mx-auto max-w-2xl text-center animate-fade-in-up">
      <h2 class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        <span
          style="text-shadow: -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 1px 1px 0 #fff, 0 0 8px rgba(255,255,255,0.5);"
        >
          El acrónimo{" "}
        </span>
        <span class="animate-gradient-text">ERES</span>
      </h2>
      <p
        style="text-shadow: -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 1px 1px 0 #fff, 0 0 8px rgba(255,255,255,0.6);"
        class="mt-4 text-base font-normal leading-relaxed max-w-lg mx-auto sm:mt-6 sm:text-lg"
      >
        Cada letra de nuestro nombre refleja un compromiso real con la{" "}
        <span class="text-foreground font-bold">Universidad Nacional de Cajamarca</span>.
      </p>
    </div>

    <!-- ─── Pilares ERES ─── -->
    <div class="mt-20 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4 lg:gap-4">
      {pilares.map((p, i) => (
        <div
          class="group relative overflow-hidden rounded-2xl sm:rounded-3xl border border-white/60 bg-white/50 p-4 sm:p-6 backdrop-blur-xl transition-all duration-500 hover:bg-white/70 hover:shadow-[0_8px_40px_-12px] hover:shadow-primary/15 hover:-translate-y-1 dark:border-white/[0.08] dark:bg-white/[0.03] dark:hover:bg-white/[0.06] animate-fade-in-up"
          style={`animation-delay: ${300 + i * 80}ms`}
        >
          <p.Icon className="absolute -right-3 -bottom-3 h-24 w-24 sm:h-28 sm:w-28 text-primary/[0.06] transition-all duration-700 group-hover:text-primary/[0.12] group-hover:scale-110 dark:text-white/[0.04] dark:group-hover:text-white/[0.07]" />
          <div class="relative">
            <span
              style="text-shadow: -1.5px -1.5px 0 #fff, 1.5px -1.5px 0 #fff, -1.5px 1.5px 0 #fff, 1.5px 1.5px 0 #fff, 0 0 12px rgba(255,255,255,0.6);"
              class="mb-1.5 block text-4xl sm:text-5xl font-black tracking-tighter text-foreground/[1] transition-colors duration-500 group-hover:text-primary/15 dark:text-white/[0.06] dark:group-hover:text-primary/20"
            >
              {p.letter}
            </span>
            <h3 class="text-sm sm:text-base font-semibold text-foreground">{p.word}</h3>
            <p class="mt-1 text-[11px] sm:text-[13px] leading-relaxed text-muted-foreground/70">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
