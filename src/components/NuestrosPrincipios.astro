---
const valores = [
  {
    letter: "E",
    title: "Excelencia",
    desc: "La mejora continua orienta cada decisión.",
    num: "#1",
  },
  {
    letter: "R",
    title: "Responsabilidad",
    desc: "Actuamos con transparencia y rendición de cuentas.",
    num: "#2",
  },
  {
    letter: "E",
    title: "Equidad",
    desc: "Impulsamos oportunidades para toda la comunidad.",
    num: "#3",
  },
  {
    letter: "S",
    title: "Servicio",
    desc: "Ponemos a las personas y a la UNC en el centro.",
    num: "#4",
  },
];
---

<section id="nuestros-principios" class="relative overflow-hidden bg-gradient-to-br from-[#f0faf4] to-[#e8f5ec] dark:from-emerald-950/20 dark:to-emerald-950/10 py-16 sm:py-24 lg:py-28">
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Left: Header + Mascot -->
    <div class="mb-12 lg:mb-0 lg:absolute lg:top-16 lg:left-8 lg:w-[340px] xl:left-16 xl:w-[380px]">
      <!-- Section label -->
      <div class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400 text-xs font-semibold uppercase tracking-widest mb-4">
        <span class="w-8 h-[2px] bg-emerald-500 rounded-full inline-block"></span>
        NUESTRA FORMA DE HACER
      </div>

      <!-- Heading -->
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-foreground leading-tight mb-4">
        El acrónimo<br />
        <span class="text-emerald-600 dark:text-emerald-400 font-bold">ERES.</span>
      </h2>

      <!-- Description -->
      <p class="text-slate-500 dark:text-slate-400 text-sm sm:text-base leading-relaxed max-w-sm mb-10 lg:mb-0">
        Cuatro principios que le dan sentido a la manera en que queremos construir una mejor UNC.
      </p>

      <!-- Mascot -->
      <div class="hidden lg:flex items-center gap-3 mt-8 pointer-events-none select-none">
        <img
          src="/yupi-pixel1-sin fondo.png"
          alt="Mascota Yupi"
          class="h-16 sm:h-20 lg:h-24 w-auto object-contain"
        />
        <div class="text-[11px] sm:text-xs font-mono text-emerald-700/80 dark:text-emerald-400/80 leading-snug">
          <p>Aprender.</p>
          <p>Mejorar.</p>
          <p>Avanzar.</p>
        </div>
      </div>
    </div>

    <!-- Right: ERES list -->
    <div class="lg:ml-[420px] xl:ml-[480px]">
      <div class="flex flex-col">
        {valores.map((v, i) => (
          <div class="group flex items-start gap-6 sm:gap-8 py-7 sm:py-8 border-t border-emerald-200/60 dark:border-emerald-800/40">
            <!-- Letter -->
            <span class="text-5xl sm:text-6xl lg:text-7xl font-black text-emerald-600 dark:text-emerald-400 leading-none shrink-0 select-none">
              {v.letter}
            </span>

            <!-- Text -->
            <div class="flex-1 min-w-0">
              <h3 class="font-heading font-bold text-foreground text-lg sm:text-xl mb-1">
                {v.title}
              </h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm sm:text-base leading-relaxed">
                {v.desc}
              </p>
            </div>

            <!-- Number -->
            <span class="text-xs text-slate-400 dark:text-slate-500 font-mono shrink-0 pt-1">
              {v.num}
            </span>
          </div>
        ))}
        <!-- Bottom border for last item -->
        <div class="border-t border-emerald-200/60 dark:border-emerald-800/40"></div>
      </div>
    </div>

    <!-- Mascot (mobile/tablet) -->
    <div class="lg:hidden flex items-center gap-3 mt-10 pointer-events-none select-none">
      <img
        src="/yupi-pixel1-sin fondo.png"
        alt="Mascota Yupi"
        class="h-16 w-auto object-contain"
      />
      <div class="text-[11px] font-mono text-emerald-700/80 dark:text-emerald-400/80 leading-snug">
        <p>Aprender.</p>
        <p>Mejorar.</p>
        <p>Avanzar.</p>
      </div>
    </div>

  </div>
</section>
