---
import { Calendar, Clock, MapPin } from "lucide-react";

const eventos = [
  {
    date: "15 de agosto, 2026",
    title: "Debate universitario: Ejes programáticos",
    time: "10:00 - 12:00",
    location: "Auditorio Central",
    type: "debate",
  },
  {
    date: "29 de agosto, 2026",
    title: "Foro estudiantil abierto",
    time: "14:00 - 17:00",
    location: "Plaza del Estudiante",
    type: "foro",
  },
  {
    date: "12 de septiembre, 2026",
    title: "Cierre de campaña — Gran conversatorio",
    time: "16:00 - 19:00",
    location: "Polideportivo Universitario",
    type: "evento",
  },
  {
    date: "20 de septiembre, 2026",
    title: "Elecciones UNC 2026",
    time: "08:00 - 18:00",
    location: "Mesas de votación en todas las facultades",
    type: "eleccion",
  },
];

const typeStyles: Record<string, string> = {
  debate: "border-l-primary bg-primary/5",
  foro: "border-l-secondary bg-secondary/5",
  evento: "border-l-primary bg-primary/10",
  eleccion: "border-l-secondary bg-secondary/10",
};

const typeLabels: Record<string, string> = {
  debate: "Debate",
  foro: "Foro",
  evento: "Evento",
  eleccion: "Elección",
};
---

<section id="calendario" class="border-t border-border/40">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
        Calendario de actividades
      </h2>
      <p class="mt-4 text-muted-foreground">
        Agenda todas las fechas clave del proceso electoral universitario.
      </p>
    </div>
    <div class="mt-12 mx-auto max-w-2xl space-y-4">
      {eventos.map((evento) => (
        <div
          class={`group relative overflow-hidden rounded-xl border border-border/40 border-l-4 p-5 transition-all hover:shadow-md ${typeStyles[evento.type]}`}
        >
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-1">
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center rounded-full border border-border/40 bg-background px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-muted-foreground">
                  {typeLabels[evento.type]}
                </span>
              </div>
              <h3 class="font-heading text-base font-semibold">
                {evento.title}
              </h3>
              <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
                <span class="flex items-center gap-1">
                  <Calendar class="h-3 w-3" />
                  {evento.date}
                </span>
                <span class="flex items-center gap-1">
                  <Clock class="h-3 w-3" />
                  {evento.time}
                </span>
                <span class="flex items-center gap-1">
                  <MapPin class="h-3 w-3" />
                  {evento.location}
                </span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
