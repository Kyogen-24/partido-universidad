---
import { Calendar, Clock, MapPin } from "lucide-react";

interface Evento {
  date: string;
  month: string;
  title: string;
  time: string;
  location: string;
  type: "debate" | "foro" | "evento" | "eleccion";
  isoStart: string;
  isoEnd: string;
}

const eventos: Evento[] = [
  {
    date: "Viernes 21 de agosto, 2026",
    month: "Agosto 2026",
    title: "Debate Descentralizado en la Sede Jaén",
    time: "10:00 am",
    location: "Auditorio Sede Jaén",
    type: "debate",
    isoStart: "2026-08-21T10:00:00-05:00",
    isoEnd: "2026-08-21T12:00:00-05:00",
  },
  {
    date: "Viernes 28 de agosto, 2026",
    month: "Agosto 2026",
    title: "Debate Descentralizado en la Sede Celendín",
    time: "10:00 am",
    location: "Auditorio Sede Celendín",
    type: "debate",
    isoStart: "2026-08-28T10:00:00-05:00",
    isoEnd: "2026-08-28T12:00:00-05:00",
  },
  {
    date: "Martes 15 de setiembre, 2026",
    month: "Setiembre 2026",
    title: "Sede Central Cajamarca",
    time: "10:00 am",
    location: "Coliseo de la UNC",
    type: "debate",
    isoStart: "2026-09-15T10:00:00-05:00",
    isoEnd: "2026-09-15T12:00:00-05:00",
  },
  {
    date: "Viernes 25 de setiembre, 2026",
    month: "Setiembre 2026",
    title: "Acto Electoral",
    time: "08:00 am - 15:00 hrs",
    location: "Ciudad Universitaria y Sedes",
    type: "eleccion",
    isoStart: "2026-09-25T08:00:00-05:00",
    isoEnd: "2026-09-25T15:00:00-05:00",
  },
  {
    date: "Viernes 25 de setiembre, 2026",
    month: "Setiembre 2026",
    title: "Escrutinio y Resultados",
    time: "15:00 - 20:00 hrs",
    location: "Comité Electoral Universitario",
    type: "eleccion",
    isoStart: "2026-09-25T15:00:00-05:00",
    isoEnd: "2026-09-25T20:00:00-05:00",
  },
  {
    date: "Lunes 28 de setiembre, 2026",
    month: "Setiembre 2026",
    title: "Credenciales y Resolución",
    time: "10:00 am",
    location: "Aula Magna",
    type: "evento",
    isoStart: "2026-09-28T10:00:00-05:00",
    isoEnd: "2026-09-28T12:00:00-05:00",
  },
];

const typeLabels: Record<Evento["type"], string> = {
  debate: "Debate",
  foro: "Foro",
  evento: "Evento",
  eleccion: "Elección",
};

const groups = eventos.reduce<{ month: string; items: Evento[] }[]>((acc, evento) => {
  const current = acc.at(-1);
  if (current && current.month === evento.month) {
    current.items.push(evento);
  } else {
    acc.push({ month: evento.month, items: [evento] });
  }
  return acc;
}, []);

const eventsSchema = eventos.map((evento) => ({
  "@context": "https://schema.org",
  "@type": "Event",
  name: evento.title,
  startDate: evento.isoStart,
  endDate: evento.isoEnd,
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  eventStatus: "https://schema.org/EventScheduled",
  location: {
    "@type": "Place",
    name: evento.location,
  },
  organizer: {
    "@type": "Organization",
    name: "Eres UNC",
    url: Astro.site?.toString(),
  },
}));
---

<section id="calendario" class="border-t border-border/40 bg-[#F3F9FF]">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
        Calendario de actividades
      </h2>
      <p class="mt-4 text-muted-foreground">
        Agenda todas las fechas clave del proceso electoral universitario.
      </p>
    </div>
    <div class="mx-auto max-w-2xl">
      {groups.map((group, groupIdx) => (
        <div class={groupIdx > 0 ? "mt-10" : ""}>
          <h3 class="reveal-item mb-4 flex items-center gap-2 pl-1 text-xs font-semibold uppercase tracking-widest text-muted-foreground">
            <Calendar class="h-4 w-4" />
            {group.month}
          </h3>
          <ol class="relative border-s border-border pl-0">
            {group.items.map((evento, idx) => {
              const isEleccion = evento.type === "eleccion";
              const isLastOverall = groupIdx === groups.length - 1 && idx === group.items.length - 1;
              return (
                <li class={`reveal-item group relative ps-6 ${isLastOverall ? "" : "mb-5"}`}>
                  <span
                    class={`absolute -start-1.5 top-6 h-3 w-3 rounded-full ring-4 ring-background transition-transform duration-300 group-hover:scale-125 ${isEleccion ? "bg-primary" : "bg-primary/40"}`}
                    aria-hidden="true"
                  ></span>
                  <div
                    class={`rounded-xl border p-4 shadow-sm transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md sm:p-5 ${isEleccion ? "border-primary/40 bg-primary/5" : "border-border bg-card"}`}
                  >
                    <div class="flex flex-wrap items-center gap-2">
                      <time class="rounded border border-border bg-muted px-1.5 py-0.5 text-xs font-medium text-foreground">
                        {evento.date}
                      </time>
                      <span
                        class={`rounded px-1.5 py-0.5 text-xs font-medium uppercase tracking-wider ${isEleccion ? "bg-primary text-primary-foreground" : "border border-primary/20 bg-primary/10 text-primary"}`}
                      >
                        {typeLabels[evento.type]}
                      </span>
                    </div>
                    <h4 class="mt-2 text-base font-semibold text-foreground sm:text-lg">
                      {evento.title}
                    </h4>
                    <div class="mt-3 flex flex-col gap-1.5 text-sm text-muted-foreground">
                      <span class="flex items-center gap-1.5">
                        <Clock class="h-3.5 w-3.5 shrink-0 opacity-70" />
                        {evento.time}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <MapPin class="h-3.5 w-3.5 shrink-0 opacity-70" />
                        {evento.location}
                      </span>
                    </div>
                  </div>
                </li>
              );
            })}
          </ol>
        </div>
      ))}
    </div>
  </div>
</section>

{eventsSchema.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}

<style>
  /* Animación de entrada al hacer scroll */
  .reveal-item {
    opacity: 0;
    transform: translateY(24px);
    filter: blur(1px);
    transition: 
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
      filter 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal-item.show {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
</style>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.05,
      rootMargin: "0px 0px -40px 0px"
    });

    const items = document.querySelectorAll(".reveal-item");
    items.forEach((item, idx) => {
      (item as HTMLElement).style.transitionDelay = `${idx * 120}ms`;
      observer.observe(item);
    });
  }

  // Run on initial load
  initReveal();

  // Run on Astro page navigation if swap is used
  document.addEventListener("astro:after-swap", initReveal);
</script>
