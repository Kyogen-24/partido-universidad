---
import { Shield, Scale, BookOpen, HeartHandshake } from "lucide-react";

const valores = [
  { title: "Autonomía universitaria", desc: "Defendemos la democracia institucional respetando la Ley Universitaria, el Estatuto y los reglamentos de la UNC.", Icon: Shield },
  { title: "Ética e integridad", desc: "Actuamos con rendición de cuentas, transparencia y meritocracia en cada decisión.", Icon: Scale },
  { title: "Libertad de cátedra", desc: "Promovemos el pensamiento crítico, la diversidad de ideas y el respeto a la pluralidad.", Icon: BookOpen },
  { title: "Compromiso social", desc: "Vinculamos la docencia y la investigación con los problemas reales de Cajamarca y la región.", Icon: HeartHandshake },
];
---

<section id="valores" class="border-t border-border/40 bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
        Valores que nos guían
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {valores.map((v) => (
          <div class="rounded-2xl border border-border/40 bg-card p-6 transition-all hover:shadow-md">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
              <v.Icon class="h-5 w-5" />
            </div>
            <h3 class="font-heading text-lg font-semibold">{v.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
