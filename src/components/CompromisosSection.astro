---
import { Building2, BookOpen, GraduationCap, FlaskConical, Globe, ClipboardList } from "@/lib/icons";

const compromisos = [
  {
    icon: Building2,
    title: "Infraestructura y Bienestar",
    description: "Mejora de comedores y campus.",
  },
  {
    icon: BookOpen,
    title: "Apoyo Docente",
    description: "Capacitaciones y meritocracia.",
  },
  {
    icon: GraduationCap,
    title: "Beneficios Estudiantiles",
    description: "Simplificación de trámites de titulación.",
  },
  {
    icon: FlaskConical,
    title: "Investigación Activa",
    description: "Financiamiento para proyectos.",
  },
  {
    icon: Globe,
    title: "Convenios Internacionales",
    description: "Pasantías y becas globales.",
  },
  {
    icon: ClipboardList,
    title: "Transparencia",
    description: "Rendición de cuentas pública.",
  },
];
---

<section id="compromisos" class="py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <span class="inline-block rounded-full bg-eres-blue px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-white">
        Propuesta
      </span>
      <h2 class="mt-4 font-heading text-3xl font-bold text-foreground md:text-4xl lg:text-5xl">
        NUESTROS COMPROMISOS
      </h2>
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
          {compromisos.map((item) => (
            <div class="flex items-start gap-4 p-5 transition-all duration-300 hover:bg-gray-50">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-eres-blue/10">
                <item.icon class="h-6 w-6 text-eres-blue" />
              </div>
              <div>
                <h3 class="mb-1 font-heading text-sm font-bold uppercase text-foreground">
                  {item.title}
                </h3>
                <p class="text-sm text-muted-foreground">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="flex items-center justify-center">
        <div class="w-full rounded-2xl bg-eres-blue p-8 text-center shadow-xl">
          <p class="font-heading text-2xl font-bold text-white md:text-3xl">
            ¡FUERZA UNIVERSITARIA!
          </p>
          <div class="mx-auto my-4 h-1 w-16 bg-eres-green"></div>
          <p class="font-heading text-lg font-bold text-white">
            COMPROMISO ÉTICO CON LA ACADEMIA
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
