---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel";
import SectionDivider from "../components/SectionDivider.astro";
import PorQueEres from "../components/PorQueEres.astro";
import RepresentativesCarousel from "../components/RepresentativesCarousel";
import QuienesSomos from "../components/QuienesSomos.astro";
import Vision from "../components/Vision.astro";
import Mision from "../components/Mision.astro";
import Valores from "../components/Valores.astro";
import PropuestaGrid from "../components/PropuestaGrid.astro";
import PlanTrabajo from "../components/PlanTrabajo.astro";
import EventosTimeline from "../components/EventosTimeline.astro";
import TestimoniosSection from "../components/TestimoniosSection.astro";
import ContactoForm from "../components/ContactoForm";
---

<BaseLayout>
  <HeroCarousel client:load />
  <SectionDivider kicker="¿Por qué ERES?" />
  <PorQueEres />
  <SectionDivider kicker="Equipo" />
  <RepresentativesCarousel client:visible />
  <SectionDivider kicker="Quiénes somos" />
  <QuienesSomos />
  <SectionDivider kicker="Visión" />
  <Vision />
  <SectionDivider kicker="Misión" />
  <Mision />
  <SectionDivider kicker="Valores" />
  <Valores />
  <SectionDivider kicker="Propuesta" />
  <PropuestaGrid />
  <SectionDivider kicker="Plan de Trabajo" />
  <PlanTrabajo />
  <SectionDivider kicker="Calendario" />
  <EventosTimeline />
  <SectionDivider kicker="Testimonios" />
  <TestimoniosSection />
  <SectionDivider kicker="Contacto" />
  <ContactoForm client:visible />
</BaseLayout>
